# Thinkion ETL - Configuración de Ejemplo (.env.example)

# ─────────────────────────────────────────────
# Aplicación
# ─────────────────────────────────────────────
APP_NAME="Thinkion Professional ETL"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─────────────────────────────────────────────
# Base de datos Principal (MySQL - Negocio/CRM)
# ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vinson_etl
DB_USERNAME=root
DB_PASSWORD=

# ─────────────────────────────────────────────
# Base de datos Staging/Auditoría (PostgreSQL)
# ─────────────────────────────────────────────
DB_STAGING_CONNECTION=pgsql
DB_STAGING_HOST=127.0.0.1
DB_STAGING_PORT=5432
DB_STAGING_DATABASE=thinkion_etl
DB_STAGING_USERNAME=postgres
DB_STAGING_PASSWORD=

# ─────────────────────────────────────────────
# Thinkion API (Credenciales en .env privado)
# ─────────────────────────────────────────────
THINKION_CLIENT_CODE=tem9
THINKION_API_TOKEN=REDACTED_API_TOKEN
THINKION_API_TIMEOUT=60
THINKION_API_RETRIES=3

# ─────────────────────────────────────────────
# Configuración del Motor Sync
# ─────────────────────────────────────────────
THINKION_DEFAULT_REPORT_IDS=233
THINKION_DEFAULT_ESTABLISHMENTS=1,2
THINKION_SYNC_DAYS_BACK=7
THINKION_LOG_REQUESTS=true
THINKION_LOG_RESPONSES=false
